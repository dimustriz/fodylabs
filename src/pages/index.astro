---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fody Labs — Software Engineering">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Software Engineering Studio</p>
      <h1 class="hero-title">
        25+ Years of<br />
        <span class="hero-accent">Engineering Excellence</span>
      </h1>
      <p class="hero-desc">
        Desktop, web, mobile &mdash; we&rsquo;ve mastered them all. Now AI-powered.
        We build lightweight, resilient mobile apps with .NET MAUI.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
        <a href="/about" class="btn btn-outline">Learn More</a>
      </div>
    </div>
  </section>

  <!-- Island Works -->
  <section class="image-section">
    <div class="image-container">
      <img src="/island_works.svg" alt="How Island Works" class="section-image" />
    </div>
  </section>

  <!-- Expertise -->
  <section class="section" style="padding-top: 5rem; padding-bottom: 3rem;">
    <p class="section-label">What We Do</p>
    <h2 class="section-title">Full-Spectrum Platform Expertise</h2>
    <p class="section-desc">
      One team covering every platform. Native feel, shared knowledge.
    </p>

    <div class="grid-3" style="margin-top: 2.5rem;">
      <div class="card">
        <div class="card-icon">??</div>
        <h3 class="card-title">Mobile</h3>
        <p class="card-desc">
          Cross-platform mobile apps with .NET MAUI &mdash; native performance
          on Android and iOS from a single codebase.
        </p>
      </div>
      <div class="card">
        <div class="card-icon">???</div>
        <h3 class="card-title">Desktop</h3>
        <p class="card-desc">
          Windows and macOS desktop applications built with WPF, WinUI,
          and Mac Catalyst for professional workflows.
        </p>
      </div>
      <div class="card">
        <div class="card-icon">??</div>
        <h3 class="card-title">Web</h3>
        <p class="card-desc">
          Modern web solutions &mdash; from static sites and SPAs to
          full-stack platforms with ASP.NET and cloud backends.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="section">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number">25+</span>
          <span class="stat-label">Years in Business</span>
        </div>
        <div class="stat">
          <span class="stat-number">3</span>
          <span class="stat-label">Platforms</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech -->
  <section class="section" style="padding-top: 4rem; padding-bottom: 3rem;">
    <p class="section-label">Technology</p>
    <h2 class="section-title">Built on Solid Foundations</h2>
    <p class="section-desc">
      We use battle-tested technologies to deliver reliable, maintainable software.
    </p>

    <div class="tech-tags" style="margin-top: 2rem;">
      <span class="tag">.NET / C#</span>
      <span class="tag">.NET MAUI</span>
      <span class="tag">ASP.NET</span>
      <span class="tag">SQLite</span>
      <span class="tag">Azure</span>
      <span class="tag">Android</span>
      <span class="tag">iOS</span>
      <span class="tag">ExoPlayer</span>
      <span class="tag">REST APIs</span>
      <span class="tag">AI / ML</span>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 class="cta-title">Ready to build something great?</h2>
      <p class="cta-desc">
        Let&rsquo;s discuss your project. We&rsquo;ll help you choose the right
        platform and technology stack.
      </p>
      <a href="/contact" class="btn btn-primary">Contact Us</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-top: 10rem;
    padding-bottom: 5rem;
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 0%, var(--color-accent-glow) 0%, transparent 60%),
      var(--color-bg);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, var(--color-accent), #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    color: var(--color-text-muted);
    font-size: 1.15rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .grid-3 {
      grid-template-columns: 1fr;
    }
  }

  .card-icon {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .stats-section {
    padding: 4rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .image-section {
    padding: 3rem 1.5rem;
  }

  .image-container {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .section-image {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .cta-section {
    padding: 5rem 1.5rem;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
  }

  .cta-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .cta-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
</style>
