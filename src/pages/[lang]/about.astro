---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, locales, defaultLocale } from '../../i18n/index';

export function getStaticPaths() {
  return locales.filter(l => l !== defaultLocale).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<Layout title={i.about.title} description={i.about.description}>
  <section class="page-hero">
    <div class="section">
      <p class="section-label">{i.about.label}</p>
      <h1 class="page-title">{i.about.pageTitle}</h1>
      <p class="section-desc" set:html={i.about.intro} />
    </div>
  </section>

  <section class="section" style="padding-top: 3rem; padding-bottom: 3rem;">
    <div class="about-grid">
      <div>
        <h2 class="about-heading">{i.about.storyTitle}</h2>
        <p class="about-text" set:html={i.about.storyP1} />
        <p class="about-text" set:html={i.about.storyP2} />
      </div>

      <div>
        <h2 class="about-heading">{i.about.howTitle}</h2>
        <div class="values">
          <div class="value">
            <h3>{i.about.value1Title}</h3>
            <p>{i.about.value1Desc}</p>
          </div>
          <div class="value">
            <h3 set:html={i.about.value2Title} />
            <p>{i.about.value2Desc}</p>
          </div>
          <div class="value">
            <h3>{i.about.value3Title}</h3>
            <p>{i.about.value3Desc}</p>
          </div>
          <div class="value">
            <h3>{i.about.value4Title}</h3>
            <p set:html={i.about.value4Desc} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-bottom: 4rem;">
    <h2 class="section-title">{i.about.timelineTitle}</h2>
    <div class="timeline">
      <div class="timeline-item">
        <span class="timeline-year">1999</span>
        <p>{i.about.timeline1999}</p>
      </div>
      <div class="timeline-item">
        <span class="timeline-year">2005</span>
        <p set:html={i.about.timeline2005} />
      </div>
      <div class="timeline-item">
        <span class="timeline-year">2015</span>
        <p>{i.about.timeline2015}</p>
      </div>
      <div class="timeline-item">
        <span class="timeline-year">2022</span>
        <p>{i.about.timeline2022}</p>
      </div>
      <div class="timeline-item">
        <span class="timeline-year">2024</span>
        <p>{i.about.timeline2024}</p>
      </div>
    </div>
  </section>

  <section class="section fody-section">
    <div class="fody-card">
      <h2 class="about-heading">{i.about.fodyTitle}</h2>
      <p class="about-text" set:html={i.about.fodyText} />
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding-top: 8rem;
    padding-bottom: 3rem;
    background:
      radial-gradient(ellipse at 30% 0%, var(--color-accent-glow) 0%, transparent 50%),
      var(--color-bg);
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .about-heading {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .about-text {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .values {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .value {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }

  .value h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .value p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  /* Timeline */
  .timeline {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-item:last-child {
    border-bottom: none;
  }

  .timeline-year {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    min-width: 3rem;
    flex-shrink: 0;
  }

  .timeline-item p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .fody-section {
    padding-bottom: 4rem;
  }

  .fody-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2.5rem;
    max-width: 720px;
  }

  .fody-card .about-heading {
    margin-bottom: 1rem;
  }

  .fody-card .about-text {
    margin-bottom: 0;
  }
</style>
