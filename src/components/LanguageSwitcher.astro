---
import { locales, localeNames, getLangFromUrl } from '../i18n/index';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(new RegExp(`^/${currentLang}`), '') || '/';
---

<div class="lang-switcher">
  <button class="lang-btn" aria-label="Select language">
    {localeNames[currentLang]}
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class="lang-dropdown">
    {locales.map((lang) => {
      const href = lang === 'en' ? currentPath : `/${lang}${currentPath}`;
      return (
        <a href={href} class:list={['lang-option', { active: lang === currentLang }]}>
          {localeNames[lang]}
        </a>
      );
    })}
  </div>
</div>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font);
    padding: 0.35rem 0.6rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .lang-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.35rem;
    min-width: 140px;
    z-index: 200;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .lang-switcher:hover .lang-dropdown,
  .lang-switcher:focus-within .lang-dropdown {
    display: block;
  }

  .lang-option {
    display: block;
    padding: 0.4rem 0.6rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .lang-option:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  .lang-option.active {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
