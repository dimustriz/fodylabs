---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getLangFromUrl, t, localePath, locales } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const { title, description = i.home.heroDesc } = Astro.props;

// Decode HTML entities for use in meta tags (attributes get double-escaped)
const decodeEntities = (s: string) => s
  .replace(/&mdash;/g, '—')
  .replace(/&rsquo;/g, '\u2019')
  .replace(/&amp;/g, '&');
const metaTitle = decodeEntities(title);
const metaDesc = decodeEntities(description);

const site = 'https://fodylabs.com';
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathWithoutLang = locales.includes(pathSegments[0]) ? '/' + pathSegments.slice(1).join('/') : Astro.url.pathname;
const canonicalPath = lang === 'en' ? pathWithoutLang : `/${lang}${pathWithoutLang}`;
const canonicalURL = new URL(canonicalPath, site).href.replace(/\/+$/, '') || site;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDesc} />
    <link rel="canonical" href={canonicalURL} />
    {locales.map((l) => {
      const href = l === 'en'
        ? new URL(pathWithoutLang, site).href.replace(/\/+$/, '') || site
        : new URL(`/${l}${pathWithoutLang}`, site).href.replace(/\/+$/, '');
      return <link rel="alternate" hreflang={l} href={href} />;
    })}
    <link rel="alternate" hreflang="x-default" href={new URL(pathWithoutLang, site).href.replace(/\/+$/, '') || site} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${site}/fodylabs-icon.png`} />
    <meta property="og:locale" content={lang} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <link rel="icon" type="image/png" href="/fodylabs-icon.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={localePath(lang, '/')} class="logo">Fody Labs</a>
        <div class="nav-links">
          <a href={localePath(lang, '/')}>{i.nav.home}</a>
          <a href={localePath(lang, '/about')}>{i.nav.about}</a>
          <a href={localePath(lang, '/contact')}>{i.nav.contact}</a>
          <LanguageSwitcher />
        </div>
        <button class="menu-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu">
      <a href={localePath(lang, '/')}>{i.nav.home}</a>
      <a href={localePath(lang, '/about')}>{i.nav.about}</a>
      <a href={localePath(lang, '/contact')}>{i.nav.contact}</a>
      <LanguageSwitcher />
    </div>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div>
            <h3 class="footer-brand">Fody Labs</h3>
            <p class="footer-tagline">{i.footer.tagline}</p>
          </div>
          <div>
            <h4 class="footer-heading">{i.footer.contactHeading}</h4>
            <p><a href="mailto:info@fodylabs.com">info@fodylabs.com</a></p>
          </div>
          <div>
            <h4 class="footer-heading">{i.footer.linksHeading}</h4>
            <p><a href={localePath(lang, '/about')}>{i.nav.about}</a></p>
            <p><a href={localePath(lang, '/contact')}>{i.nav.contact}</a></p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} {i.footer.copyright}</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.menu-toggle');
      const menu = document.querySelector('.mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('open');
        toggle.classList.toggle('open');
      });

      // Browser language detection (only on first visit)
      const SUPPORTED = ['en', 'de', 'ru', 'uk', 'es', 'it', 'fr'];
      if (!sessionStorage.getItem('lang-redirected')) {
        sessionStorage.setItem('lang-redirected', '1');
        const path = window.location.pathname;
        const currentLang = SUPPORTED.find(l => path.startsWith('/' + l + '/') || path === '/' + l) || 'en';
        if (currentLang === 'en' && path === '/') {
          const browserLang = navigator.language.split('-')[0];
          if (SUPPORTED.includes(browserLang) && browserLang !== 'en') {
            window.location.replace('/' + browserLang + '/');
          }
        }
      }
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-bg: #0a0a0f;
    --color-surface: #12121a;
    --color-border: #1e1e2e;
    --color-text: #e4e4e7;
    --color-text-muted: #71717a;
    --color-accent: #6366f1;
    --color-accent-hover: #818cf8;
    --color-accent-glow: rgba(99, 102, 241, 0.15);
    --color-nav-bg: rgba(10, 10, 15, 0.85);
    --font: 'Inter', system-ui, -apple-system, sans-serif;
    --max-width: 1100px;
    --radius: 12px;
  }

  @media (prefers-color-scheme: light) {
    :root {
      --color-bg: #ffffff;
      --color-surface: #f4f4f5;
      --color-border: #e4e4e7;
      --color-text: #18181b;
      --color-text-muted: #71717a;
      --color-accent: #4f46e5;
      --color-accent-hover: #6366f1;
      --color-accent-glow: rgba(79, 70, 229, 0.1);
      --color-nav-bg: rgba(255, 255, 255, 0.85);
    }
  }

  html {
    font-family: var(--font);
    background: var(--color-bg);
    color: var(--color-text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent-hover);
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-nav-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text) !important;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    z-index: 99;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    flex-direction: column;
    padding: 1rem 1.5rem;
    gap: 0.75rem;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu a {
    color: var(--color-text-muted);
    font-size: 1rem;
    padding: 0.5rem 0;
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }
  }

  /* Footer */
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 3rem 1.5rem 1.5rem;
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  .footer-brand {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-heading {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .footer p {
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .footer p a {
    color: var(--color-text-muted);
  }

  .footer p a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  /* Shared section styles */
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .section-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 600px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    font-family: var(--font);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px var(--color-accent-glow);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 30px var(--color-accent-glow);
  }
</style>
